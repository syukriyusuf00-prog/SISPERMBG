rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.peran == 'ADMIN';
    }

    // 3. User Profile Validation Helper
    function isValidUserProfile(userId, data) {
      return data.uid == userId
        && data.email is string
        && data.email.size() <= 256
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    // 4. Secure Collections Matching
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) 
        && isValidId(userId)
        && (
          (request.auth.token.email == 'syukriyusuf82@gmail.com' && incoming().peran == 'ADMIN' && incoming().statusPersetujuan == 'aktif') ||
          (request.auth.token.email != 'syukriyusuf82@gmail.com' && incoming().peran == 'USER' && incoming().statusPersetujuan == 'menunggu')
        )
        && incoming().keys().hasAll(['uid', 'email', 'createdAt', 'updatedAt'])
        && isValidUserProfile(userId, incoming());
        
      allow update: if isAdmin() || (
        isOwner(userId)
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().email == existing().email
        && (
          (request.auth.token.email == 'syukriyusuf82@gmail.com' && incoming().peran == 'ADMIN' && incoming().statusPersetujuan == 'aktif') ||
          (
            incoming().peran == existing().peran 
            && incoming().statusPersetujuan == existing().statusPersetujuan
            && incoming().berakhirPada == existing().berakhirPada
          )
        )
      );
        
      allow delete: if isAdmin();

      // Sub-collection for user state slices (profile, sekolah, tigab, menu, foodCost, tkpi, customLogo)
      match /states/{stateKey} {
        allow get, list: if isOwner(userId) || isAdmin();
        
        allow create: if isOwner(userId)
          && isValidId(stateKey)
          && incoming().keys().hasAll(['userId', 'stateKey', 'data', 'updatedAt'])
          && incoming().keys().size() == 4
          && incoming().userId == userId
          && incoming().stateKey == stateKey
          && incoming().data is string
          && incoming().data.size() <= 512000
          && incoming().updatedAt == request.time;

        allow update: if isOwner(userId)
          && incoming().userId == userId
          && incoming().stateKey == stateKey
          && incoming().data is string
          && incoming().data.size() <= 512000
          && incoming().updatedAt == request.time;
          
        allow delete: if isOwner(userId) || isAdmin();
      }
    }
  }
}
