rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 3. User Profile Validation Helper
    function isValidUserProfile(userId, data) {
      return data.uid == userId
        && data.email is string
        && data.email.size() <= 256
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    // 4. Secure Collections Matching
    match /users/{userId} {
      allow get: if isOwner(userId);
      
      allow create: if isOwner(userId) 
        && isValidId(userId)
        && incoming().keys().hasAll(['uid', 'email', 'createdAt', 'updatedAt'])
        && incoming().keys().size() == 4
        && isValidUserProfile(userId, incoming());
        
      allow update: if isOwner(userId)
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().email is string
        && incoming().email.size() <= 256;
        
      allow delete: if false; // User accounts cannot be deleted directly from client

      // Sub-collection for user state slices (profile, sekolah, tigab, menu, foodCost, tkpi, customLogo)
      match /states/{stateKey} {
        allow get, list: if isOwner(userId);
        
        allow create: if isOwner(userId)
          && isValidId(stateKey)
          && incoming().keys().hasAll(['userId', 'stateKey', 'data', 'updatedAt'])
          && incoming().keys().size() == 4
          && incoming().userId == userId
          && incoming().stateKey == stateKey
          && incoming().data is string
          // Secure range check: maximum of 512,000 characters (~500KB) to prevent Denial of Wallet bloating
          && incoming().data.size() <= 512000
          && incoming().updatedAt == request.time;

        allow update: if isOwner(userId)
          && incoming().userId == userId
          && incoming().stateKey == stateKey
          && incoming().data is string
          && incoming().data.size() <= 512000
          && incoming().updatedAt == request.time;
          
        allow delete: if isOwner(userId);
      }
    }
  }
}
